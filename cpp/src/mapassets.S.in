/* The page's four ingredients, baked into the binary.
 *
 * Rust uses include_str!; C++ has no equivalent before C++23's #embed (gcc 15+),
 * and a 1.3 MB raw string literal makes the compiler chew through a megabyte of
 * source for no reason. The assembler already knows how to paste a file into
 * a read-only section, so it does. Paths are absolute, substituted by CMake
 * from cpp/assets.
 *
 * Two dialects, one file: ELF wants .section .rodata and bare symbol names;
 * Mach-O wants __TEXT,__const and a leading underscore on every C symbol.
 * The .S extension runs the C preprocessor, so SYM() papers over the gap.
 */
#ifdef __APPLE__
#define SYM(x) _##x
    .section __TEXT,__const
#else
#define SYM(x) x
    .section .rodata
#endif

    .globl SYM(cml_map_html)
    .globl SYM(cml_map_html_end)
SYM(cml_map_html):
    .incbin "@CML_ASSET_DIR@/map.html"
SYM(cml_map_html_end):
    .byte 0

    .globl SYM(cml_three_js)
    .globl SYM(cml_three_js_end)
SYM(cml_three_js):
    .incbin "@CML_ASSET_DIR@/vendor/three.module.js"
SYM(cml_three_js_end):
    .byte 0

    .globl SYM(cml_controls_js)
    .globl SYM(cml_controls_js_end)
SYM(cml_controls_js):
    .incbin "@CML_ASSET_DIR@/vendor/OrbitControls.js"
SYM(cml_controls_js_end):
    .byte 0

    .globl SYM(cml_app_js)
    .globl SYM(cml_app_js_end)
SYM(cml_app_js):
    .incbin "@CML_ASSET_DIR@/app.js"
SYM(cml_app_js_end):
    .byte 0

#ifndef __APPLE__
    .section .note.GNU-stack,"",@progbits
#endif
