{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cml-run\" index >/dev/null 2>&1 || true"
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cml-run\" capture || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/cml-run\" nudge"
          }
        ]
      }
    ]
  }
}
