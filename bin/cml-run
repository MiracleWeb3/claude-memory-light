#!/bin/sh
# claude-memory-light bootstrap: resolve the cml binary, then exec it.
# Resolution order: installed binary -> PATH -> prebuilt release download -> cmake build.
# Design law: a memory hook must NEVER block or break the session — this script
# always exits 0 and emits valid passthrough JSON for nudge even when nothing works.

BIN_DIR="${CML_HOME:-$HOME/.claude/claude-memory-light}/bin"
BIN="$BIN_DIR/cml"
ROOT="$(cd "$(dirname "$0")/.." && pwd)"

if [ ! -x "$BIN" ] && command -v cml >/dev/null 2>&1; then
    BIN="$(command -v cml)"
fi

if [ ! -x "$BIN" ]; then
    mkdir -p "$BIN_DIR" 2>/dev/null
    OS=$(uname -s | tr '[:upper:]' '[:lower:]')
    ARCH=$(uname -m)
    URL="https://github.com/MiracleWeb3/claude-memory-light/releases/latest/download/cml-$OS-$ARCH"
    if command -v curl >/dev/null 2>&1; then
        curl -fsSL --max-time 60 -o "$BIN_DIR/cml" "$URL" 2>/dev/null && chmod +x "$BIN_DIR/cml" && BIN="$BIN_DIR/cml"
    fi
fi

# Last resort: build from source. Needs cmake, a C++20 compiler, and the sqlite3 and
# simdjson headers; sqlite-vec is vendored in the tree.
if [ ! -x "$BIN" ] && command -v cmake >/dev/null 2>&1; then
    (cd "$ROOT/cpp" && cmake -S . -B build >/dev/null 2>&1 && cmake --build build -j2 >/dev/null 2>&1) \
        && cp "$ROOT/cpp/build/cml" "$BIN_DIR/cml" 2>/dev/null \
        && chmod +x "$BIN_DIR/cml" && BIN="$BIN_DIR/cml"
fi

if [ -x "$BIN" ]; then
    exec "$BIN" "$@"
fi

# Graceful degradation: never break the session.
case "$1" in
    nudge|hint) echo '{"continue":true}' ;;
esac
exit 0
